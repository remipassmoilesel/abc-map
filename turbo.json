{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "stream",
  "globalEnv": ["CI", "ABC_CONFIGURATION", "CYPRESS_CACHE_FOLDER", "NODE_OPTIONS"],
  "tasks": {
    "lint": {},
    "lint:fix": {},
    "write-version": {
      "cache": false
    },
    "dependency-check": {},
    "clean": {
      "cache": false
    },
    "clean-build": {
      "dependsOn": ["^clean-build"],
      "outputs": ["build/**"]
    },
    "package": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:with-servers": {
      "dependsOn": ["^test:with-servers"]
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "start:ci": {
      "cache": false,
      "persistent": true
    },
    "watch": {
      "cache": false,
      "persistent": true
    }
  }
}
