{
  "name": "@abc-map/performance-tests",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build"
  ],
  "scripts": {
    "build": "webpack",
    "clean": "rm -rf build",
    "clean-build": "pnpm run clean && pnpm run build",
    "dependency-check": "depcruise -c .dependency-cruiser.js src",
    "init": "node scripts/init.js",
    "lint": "prettier --log-level warn --check . && eslint './src/**/{*.tsx,*.ts}' --max-warnings=0 && sort-package-json --check",
    "lint:fix": "prettier --log-level warn --write . && eslint './src/**/{*.tsx,*.ts}' --max-warnings=0 --fix && sort-package-json",
    "test:performance:staging": "pnpm run init && k6 run build/index.js -e CONFIG_FILE=$(pwd)/config/staging.json --summary-export=test-results.json && node scripts/check-results.js",
    "test:with-servers": "pnpm run init && k6 run build/index.js -e CONFIG_FILE=$(pwd)/config/ci.json --summary-export=test-results.json && node scripts/check-results.js",
    "type-check": "tsc --noEmit",
    "watch": "webpack -w"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "url-join": "^5.0.0",
    "uuid-random": "^1.3.2"
  },
  "devDependencies": {
    "@abc-map/shared": "workspace:*",
    "@eslint/js": "^9.39.1",
    "@types/k6": "1.6.0",
    "@types/webpack": "5.28.5",
    "clean-webpack-plugin": "^4.0.0",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^9.39.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^17.3.0",
    "prettier": "3.8.1",
    "sort-package-json": "^3.6.1",
    "ts-loader": "^9.5.4",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.46.4",
    "webpack": "5.105.3",
    "webpack-cli": "6.0.1"
  }
}
