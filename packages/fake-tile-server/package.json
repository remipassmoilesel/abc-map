{
  "name": "@abc-map/fake-tile-server",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dependency-check": "depcruise -c .dependency-cruiser.js src",
    "lint": "prettier --log-level warn --check . && eslint './src/**/{*.tsx,*.ts}' --max-warnings=0 && sort-package-json --check",
    "lint:fix": "prettier --log-level warn --write . && eslint './src/**/{*.tsx,*.ts}' --max-warnings=0 --fix && sort-package-json",
    "start": "tsx src/main.ts",
    "start:ci": "tsx src/main.ts",
    "type-check": "tsc --noEmit",
    "watch": "tsc --watch --preserveWatchOutput --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^9.39.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "globals": "^17.3.0",
    "sort-package-json": "^3.6.1",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.46.4"
  }
}
