{
  "name": "@abc-map/shared",
  "version": "1.0.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf build",
    "clean-build": "pnpm run clean && pnpm run build",
    "coverage": "vitest run --coverage",
    "dependency-check": "depcruise -c .dependency-cruiser.js src",
    "lint": "prettier --log-level warn --check . && eslint './src/**/{*.tsx,*.ts}' --max-warnings=0 && sort-package-json --check",
    "lint:fix": "prettier --log-level warn --write . && eslint './src/**/{*.tsx,*.ts}' --max-warnings=0 --fix && sort-package-json",
    "test": "vitest run",
    "test:interactive": "vitest",
    "watch": "tsc --watch --preserveWatchOutput"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "loglevel": "^1.9.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/geojson": "^7946.0.10",
    "@types/node": "^24.12.2",
    "@types/semver": "^7.3.13",
    "@types/sinon": "^21.0.1",
    "blob-polyfill": "^7.0.20220408",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^9.39.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "prettier": "3.8.1",
    "semver": "^7.3.8",
    "sinon": "^21.0.3",
    "sort-package-json": "^3.6.1",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.1.2"
  }
}
