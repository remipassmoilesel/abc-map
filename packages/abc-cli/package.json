{
  "name": "@abc-map/abc-cli",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf build",
    "clean-build": "pnpm run clean && pnpm run build",
    "coverage": "vitest run --coverage",
    "dependency-check": "depcruise -c .dependency-cruiser.js src",
    "lint": "prettier --log-level warn --check . && eslint './src/**/{*.tsx,*.ts}' --max-warnings=0 && sort-package-json --check",
    "lint:fix": "prettier --log-level warn --write . && eslint './src/**/{*.tsx,*.ts}' --max-warnings=0 --fix && sort-package-json",
    "test": "vitest run",
    "test:interactive": "vitest",
    "watch": "tsc --watch --preserveWatchOutput"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "loglevel": "^1.9.2",
    "source-map-support": "^0.5.21",
    "wait-on": "^9.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.12.2",
    "@types/wait-on": "^5.3.1",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^9.39.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "globals": "^17.3.0",
    "prettier": "3.8.1",
    "sort-package-json": "^3.6.1",
    "turbo": "^2.9.6",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.1.2"
  }
}
