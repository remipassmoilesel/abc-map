{
  "name": "@abc-map/e2e-tests",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf build && rm -rf emails",
    "clean-build": "pnpm run clean && pnpm run build",
    "dependency-check": "depcruise -c .dependency-cruiser.js src",
    "e2e:headless:10082": "ABC_CYPRESS_BASE_URL=http://localhost:10082 cypress run --browser chromium --headless",
    "e2e:headless:3005": "cypress run --browser chromium --headless",
    "e2e:interactive:10082": "ABC_CYPRESS_BASE_URL=http://localhost:10082 cypress open --browser chromium",
    "e2e:interactive:3005": "cypress open --browser chromium",
    "lint": "prettier --log-level warn --check . && eslint './src/**/{*.tsx,*.ts}' --max-warnings=0 && sort-package-json --check",
    "lint:fix": "prettier --log-level warn --write . && eslint './src/**/{*.tsx,*.ts}' --max-warnings=0 --fix && sort-package-json",
    "test:with-servers": "pnpm run e2e:headless:10082",
    "watch": "tsc --watch --preserveWatchOutput"
  },
  "devDependencies": {
    "@abc-map/shared": "workspace:*",
    "@eslint/js": "^9.39.1",
    "@testing-library/cypress": "^10.1.0",
    "@types/lodash": "^4.14.199",
    "@types/pixelmatch": "^5.2.4",
    "@types/pngjs": "^6.0.0",
    "caniuse-lite": "^1.0.30001603",
    "cypress": "15.11.0",
    "cypress-file-upload": "^5.0.8",
    "cypress-slow-down": "^1.4.0",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^9.39.1",
    "eslint-plugin-cypress": "^6.2.2",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "globals": "^17.3.0",
    "lodash": "^4.17.23",
    "nanoid": "^5.1.5",
    "pixelmatch": "^5.3.0",
    "pngjs": "^6.0.0",
    "prettier": "3.8.1",
    "sort-package-json": "^3.6.1",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.46.4",
    "uuid-random": "^1.3.2"
  }
}
