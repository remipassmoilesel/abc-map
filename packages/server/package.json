{
  "name": "@abc-map/server",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "build/main.js",
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf build && rm -rf public",
    "clean-build": "pnpm run clean && pnpm run build",
    "coverage": "vitest run --coverage",
    "dependency-check": "depcruise -c .dependency-cruiser.js src",
    "lint": "prettier --log-level warn --check . && eslint './src/**/{*.tsx,*.ts}' --max-warnings=0 && sort-package-json --check",
    "lint:fix": "prettier --log-level warn --write . && eslint './src/**/{*.tsx,*.ts}' --max-warnings=0 --fix && sort-package-json",
    "start": "nodemon --trace-warnings --watch build --watch resources ./build/main.js",
    "start:ci": "node ./build/main.js",
    "test": "vitest run",
    "test:interactive": "vitest",
    "watch": "tsc --watch --preserveWatchOutput",
    "write-version": "tsx scripts/version.ts"
  },
  "dependencies": {
    "@abc-map/shared": "workspace:*",
    "@fastify/error": "^4.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.0.0",
    "@fastify/view": "^11.1.1",
    "accept-language-parser": "^1.5.0",
    "ajv": "8.12.0",
    "bson": "^7.1.1",
    "fast-xml-parser": "^5.2.5",
    "fastify": "5.8.4",
    "fastify-metrics": "^13.2.0",
    "glob": "^13.0.6",
    "handlebars": "^4.7.9",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "mongodb": "^7.1.1",
    "ms": "^2.1.3",
    "nodemailer": "^8.0.4",
    "prom-client": "^15.1.3",
    "source-map-support": "^0.5.21",
    "uuid-random": "^1.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/accept-language-parser": "^1.5.8",
    "@types/geojson": "^7946.0.10",
    "@types/glob": "^8.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/luxon": "^3.7.1",
    "@types/ms": "^2.1.0",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^8.0.0",
    "@types/sinon": "^21.0.1",
    "@types/source-map-support": "^0.5.10",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^9.39.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "form-data": "^4.0.5",
    "globals": "^17.3.0",
    "nodemon": "^3.1.14",
    "prettier": "3.8.1",
    "sinon": "^21.0.3",
    "sort-package-json": "^3.6.1",
    "tsx": "^4.21.0",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.1.2"
  },
  "docker": {
    "imageName": "server"
  }
}
