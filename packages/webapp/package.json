{
  "name": "@abc-map/webapp",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "build": "pnpm run build:changelog && pnpm run generate-pwa-assets && pnpm run type-check && vite build --mode production && pnpm run build:check",
    "build:changelog": "./scripts/build-changelog.js",
    "build:check": "node scripts/check-build.js",
    "clean": "rm -rf build",
    "clean-build": "pnpm run clean && pnpm run build",
    "coverage": "vitest run --coverage",
    "dependency-check": "depcruise -c .dependency-cruiser.js src",
    "generate-pwa-assets": "pwa-assets-generator --preset minimal-2023 public/logo.svg",
    "lint": "prettier --log-level warn --check . && eslint './src/**/{*.tsx,*.ts}' --max-warnings=0 && sort-package-json --check",
    "lint:fix": "prettier --log-level warn --write . && eslint './src/**/{*.tsx,*.ts}' --max-warnings=0 --fix && sort-package-json",
    "package": "./scripts/package.js",
    "preview": "vite preview",
    "start": "vite",
    "test": "vitest run",
    "test:interactive": "vitest",
    "type-check": "tsc -b",
    "watch": "tsc -b --watch --preserveWatchOutput",
    "write-version": "tsx scripts/version.ts"
  },
