{
  "name": "@abc-map/user-documentation",
  "version": "1.0.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsx scripts/sass.ts && eleventy",
    "clean": "rm -rf build",
    "clean-build": "pnpm run clean && pnpm run build",
    "dependency-check": "depcruise -c .dependency-cruiser.js src",
    "lint": "prettier --log-level warn --check . && sort-package-json --check",
    "lint:fix": "prettier --log-level warn --write . && sort-package-json",
    "package": "tsx ./scripts/package.ts",
    "start": "concurrently 'eleventy --serve --port=8085' 'pnpm run watch:styles'",
    "test:with-servers": "tsx ./scripts/test.ts",
    "watch": "concurrently 'pnpm run watch:eleventy' 'pnpm run watch:styles'",
    "watch:eleventy": "eleventy --watch",
    "watch:styles": "tsx ./scripts/sass.ts --watch"
  },
  "dependencies": {
    "@abc-map/shared": "workspace:*",
    "bootstrap": "5.3.8",
    "i18next": "^25.8.13"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@types/node": "^24.12.2",
    "axios": "^1.13.6",
    "concurrently": "^9.2.1",
    "dependency-cruiser": "^17.3.8",
    "eleventy-plugin-nesting-toc": "^1.3.0",
    "fast-glob": "^3.3.3",
    "html-validate": "^10.9.0",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "node-html-parser": "^7.0.2",
    "prettier": "3.8.1",
    "sass-embedded": "1.78.0",
    "slugify": "^1.6.6",
    "sort-package-json": "^3.6.1",
    "tsx": "^4.21.0"
  }
}
