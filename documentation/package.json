{
  "name": "@abc-map/developer-documentation",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "build": "node scripts/toc.js && prettier --write .",
    "clean": "rm -rf build",
    "clean-build": "pnpm run clean && pnpm run build",
    "lint": "prettier --log-level warn --check . && sort-package-json --check",
    "lint:fix": "prettier --log-level warn --write . && sort-package-json"
  },
  "dependencies": {
    "markdown-toc": "^1.2.0",
    "prettier": "3.8.1",
    "sort-package-json": "^3.6.1"
  }
}
